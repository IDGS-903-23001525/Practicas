<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A3175"
    tools:context="Practica3.Practica3Activity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Datos Personales"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre"
                android:textColor="#000000"
                android:inputType="textPersonName"
                android:padding="14dp" android:background="@android:drawable/edit_text" android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etApaterno"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Apellido Paterno"
                android:textColor="#000000"
                android:inputType="textPersonName"
                android:padding="14dp" android:background="@android:drawable/edit_text" android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etAmaterno"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Apellido Materno"
                android:textColor="#000000"
                android:inputType="textPersonName"
                android:padding="14dp" android:background="@android:drawable/edit_text" android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fecha de nacimiento"
                android:textColor="#000000"
                android:textStyle="bold"
                android:padding="14dp" android:background="@android:drawable/edit_text" android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etDia"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Día (22)"
                    android:textColor="#000000"
                    android:inputType="number"
                    android:padding="14dp" android:background="@android:drawable/edit_text" android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/etMes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Mes (02)"
                    android:textColor="#000000"
                    android:inputType="number"
                    android:padding="14dp" android:background="@android:drawable/edit_text" android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/etAnio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Año (1990)"
                    android:textColor="#000000"
                    android:inputType="number"
                    android:padding="14dp" android:background="@android:drawable/edit_text" android:layout_marginBottom="12dp"/>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sexo"
                android:textColor="#000000"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <RadioGroup
                android:id="@+id/rgSexo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <RadioButton
                    android:id="@+id/rbMasculino"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Masculino"
                    android:textColor="#000000"
                    android:layout_marginRight="24dp" />

                <RadioButton
                    android:id="@+id/rbFemenino"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Femenino"
                    android:textColor="#000000"/>
            </RadioGroup>

            <Button
                android:id="@+id/btnImprimir"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Imprimir"
                android:layout_marginBottom="24dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#D3D3D3"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/tvResultadoNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold|italic"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvResultadoEdad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvResultadoSigno"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:layout_marginBottom="12dp" />

            <ImageView
                android:id="@+id/imgSigno"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center_horizontal"
                android:visibility="gone"
                tools:src="@android:drawable/ic_menu_gallery" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>