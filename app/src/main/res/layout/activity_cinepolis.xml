<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A3175"
    android:fillViewport="true"
    tools:context=".Practica5.CinepolisActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:paddingHorizontal="24dp"
            android:paddingVertical="6dp"
            android:text="Cinépolis"
            android:textColor="#1A3175"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="10dp"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardEntradas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/cardSalidas"
            app:layout_constraintHorizontal_weight="1.3">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entradas"
                    android:textColor="#1A3175"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="14dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre:"
                    android:textColor="#555555"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <EditText
                    android:id="@+id/etNombre"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:background="@android:drawable/edit_text"
                    android:textColor="#000000"
                    android:paddingHorizontal="8dp"
                    android:inputType="textPersonName"
                    android:layout_marginBottom="12dp"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cantidad Compradores:"
                    android:textColor="#555555"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <EditText
                    android:id="@+id/etCantidadCompradores"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:background="@android:drawable/edit_text"
                    android:textColor="#000000"
                    android:paddingHorizontal="8dp"
                    android:inputType="number"
                    android:layout_marginBottom="12dp"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tarjeta Cineco:"
                    android:textColor="#555555"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <RadioGroup
                    android:id="@+id/rgTarjetaCineco"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <RadioButton
                        android:id="@+id/rbSiCineco"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sí"
                        android:textColor="#000000"
                        android:layout_marginEnd="12dp"/>
                    <RadioButton
                        android:id="@+id/rbNoCineco"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No"
                        android:textColor="#000000"
                        android:checked="true"/>
                </RadioGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cantidad de Boletas:"
                    android:textColor="#555555"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <EditText
                    android:id="@+id/etCantidadBoletas"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:background="@android:drawable/edit_text"
                    android:textColor="#000000"
                    android:paddingHorizontal="8dp"
                    android:inputType="number"
                    android:textSize="14sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardSalidas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            android:layout_marginStart="10dp"
            app:layout_constraintTop_toTopOf="@+id/cardEntradas"
            app:layout_constraintStart_toEndOf="@+id/cardEntradas"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="0.9">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Salidas"
                    android:textColor="#1A3175"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="14dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Valor a Pagar"
                    android:textColor="#555555"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:id="@+id/tvValorPagar"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:background="#F0F4FF"
                    android:textColor="#1A3175"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:text="$0.00"
                    android:textSize="16sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvEslogan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cinépolis"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold|italic"
            android:layout_marginTop="36dp"
            app:layout_constraintTop_toBottomOf="@id/cardEntradas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvSubEslogan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LA CAPITAL DEL CINE"
            android:textColor="#DFE6FF"
            android:textSize="12sp"
            android:letterSpacing="0.2"
            app:layout_constraintTop_toBottomOf="@id/tvEslogan"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="25dp"
            app:cardElevation="4dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubEslogan"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:background="#FFFFFF">

                <Button
                    android:id="@+id/btnProcesar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Procesar"
                    android:backgroundTint="#1A3175"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnSalir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Salir"
                    android:backgroundTint="#D9383A"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>